# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/dealbot

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY=change-me-to-a-long-random-string

# LLM backend: "ollama" (local dev) or "vllm" (prod)
LLM_BACKEND=ollama

# Ollama (used when LLM_BACKEND=ollama)
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://host.docker.internal:11434

# vLLM (used when LLM_BACKEND=vllm) — point at your cloud-hosted vLLM instance
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Brave Search API (Phase 7)
BRAVE_API_KEY=
BRAVE_SEARCH_N=10

# Resend email (Phase 9)
RESEND_API_KEY=
RESEND_FROM=Studeal <alerts@studeal.site>
