# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/dealbot

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY=change-me-to-a-long-random-string

# LLM backend: "openai" (recommended), "groq", "ollama" (local dev), or "vllm" (self-hosted)
LLM_BACKEND=openai

# Ollama (used when LLM_BACKEND=ollama)
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://host.docker.internal:11434

# vLLM (used when LLM_BACKEND=vllm) — point at your cloud-hosted vLLM instance
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# OpenAI (used when LLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (used when LLM_BACKEND=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Search providers ---
# Tavily — AI-native semantic search (https://tavily.com)
TAVILY_API_KEY=
# Serper — Google Shopping structured results (https://serper.dev)
SERPER_API_KEY=
# Firecrawl — content extraction + search (https://firecrawl.dev)
FIRECRAWL_API_KEY=

# Browserbase (used only for community RSS source extraction)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Resend email
RESEND_API_KEY=
RESEND_FROM=Studeal <alerts@studeal.site>

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_SUCCESS_URL=https://studeal.site/dashboard?upgraded=1
STRIPE_CANCEL_URL=https://studeal.site/watchlists

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Sentry error tracking (get DSN from sentry.io — free tier is sufficient)
SENTRY_DSN=
